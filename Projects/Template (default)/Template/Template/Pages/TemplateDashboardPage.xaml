<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Template.Pages.TemplateDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Template.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Template.Data.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*" x:Name="LeftColumn"/>
            <ColumnDefinition Width="70*" x:Name="ContentColumn"/>
            <ColumnDefinition Width="15*" x:Name="RightColumn"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="1" Background="#F5F5F5">
            <Grid Grid.Column="1" Background="#F5F5F5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Filter Bar ── -->
                <Grid Grid.Row="0" Margin="0,24,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <TextBox
                    Grid.Column="0"
                    PlaceholderText="Search..."
                    Margin="0,0,10,0"
                    Height="36"
                    VerticalContentAlignment="Center"
                    Background="White"
                    BorderBrush="#3a7ff9"
                    BorderThickness="1"
                    CornerRadius="6"/>

                    <!-- Filter 2 -->
                    <ComboBox
                    Grid.Column="1"
                    PlaceholderText="Status"
                    Width="130"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="White"
                    BorderBrush="#3a7ff9"
                    BorderThickness="1"
                    CornerRadius="6">
                        <ComboBoxItem Content="Active"/>
                        <ComboBoxItem Content="Inactive"/>
                    </ComboBox>

                    <!-- Filter 3 -->
                    <ComboBox
                    Grid.Column="2"
                    PlaceholderText="Category"
                    Width="130"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="White"
                    BorderBrush="#3a7ff9"
                    BorderThickness="1"
                    CornerRadius="6">
                        <ComboBoxItem Content="Category A"/>
                        <ComboBoxItem Content="Category B"/>
                    </ComboBox>

                    <!-- Filter 4 -->
                    <ComboBox
                    Grid.Column="3"
                    PlaceholderText="Sort by"
                    Width="130"
                    Height="36"
                    Background="White"
                    BorderBrush="#3a7ff9"
                    BorderThickness="1"
                    CornerRadius="6">
                        <ComboBoxItem Content="ID"/>
                        <ComboBoxItem Content="Name"/>
                    </ComboBox>
                </Grid>

                <!-- ── Table ── -->
                <Border
                Grid.Row="1"
                Background="White"
                CornerRadius="10"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Margin="0,0,0,24">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border
                        Grid.Row="0"
                        Background="#3a7ff9"
                        CornerRadius="10,10,0,0"
                        Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ID"   Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Name" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Rows -->
                        <ListView x:Name="ItemsList" Grid.Row="1"
                              SelectionMode="Single" IsItemClickEnabled="True"
                              ItemClick="ItemsList_ItemClick">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="MinHeight" Value="46"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ItemModel">
                                    <Grid MinHeight="46">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#EBF2FF" CornerRadius="5" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Id}" Foreground="#3a7ff9" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}"       Foreground="#1A1A2E" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind Email}"      Foreground="#555"    FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind Department}" Foreground="#1A1A2E" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{x:Bind Status}"     Foreground="#1A1A2E" FontSize="13" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
