<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Template.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Template.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="70*" MaxHeight="500"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32.5*"/>
            <ColumnDefinition Width="35*" MaxWidth="450"/>
            <ColumnDefinition Width="32.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Logo -->
        <StackPanel Grid.RowSpan="3" 
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal" 
                    VerticalAlignment="Top" 
                    Margin="24"
                    Spacing="5">
            
            <Image Source="/Assets/Square44x44Logo.png"
                   Width="60"
                   VerticalAlignment="Bottom"/>
            
            <TextBlock Text="[Company Name]"
                       FontSize="18"
                       Opacity="0.5"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="1"
              BorderBrush="#E7E7E7"
              BorderThickness="1"
              Background="#FFFFFF" 
              CornerRadius="5"
              RowSpacing="24"
              Padding="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Login" FontSize="32" FontWeight="SemiBold" VerticalAlignment="Top"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Top" Spacing="15">
                <TextBox Header="Gebruikersnaam" x:Name="UserNameBox"/>
                <PasswordBox Header="Wachtwoord" IsPasswordRevealButtonEnabled="True" x:Name="PasswordBox"/>
                <TextBlock Text=""
                           FontSize="12"
                           Foreground="Red"
                           x:Name="ErrorBox"/>
            </StackPanel>

            <StackPanel Grid.Row="2" VerticalAlignment="Top" Spacing="12">

                <!-- Login Button -->
                <Button Content="Log in" 
                        Background="#3a7ff9" 
                        HorizontalAlignment="Stretch"
                        Foreground="White"
                        FontWeight="SemiBold" 
                        FontSize="16" 
                        CornerRadius="10" 
                        Height="40"
                        x:Name="LoginButton"
                        Click="LoginButton_Click"/>

                <!-- Register Button -->
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="Nog geen accound?" FontSize="14" Opacity="0.5"/>
                    <Button Background="Transparent"
                            Foreground="#3a7ff9"
                            BorderThickness="0"
                            Padding="0"
                            x:Name="RegisterButton"
                            Click="RegisterButton_Click">
                        <TextBlock Text="Registreer" TextDecorations="Underline" />
                    </Button>
                    
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
