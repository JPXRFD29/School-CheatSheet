<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Template.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Template"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->

                <!-- 2. Your custom overrides must come SECOND -->
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <!-- Use "Light" or "Dark" explicitly if "Default" is ignored -->
                        <ResourceDictionary x:Key="Light">
                            <SolidColorBrush x:Key="RatingControlSelectedForeground" Color="#ebb82d" />
                            <SolidColorBrush x:Key="RatingControlUnselectedForeground" Color="Gray" />
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="Dark">
                            <SolidColorBrush x:Key="RatingControlSelectedForeground" Color="Gold" />
                            <SolidColorBrush x:Key="RatingControlUnselectedForeground" Color="LightGray" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
